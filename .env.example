# Agent Control Tower — backend configuration (all optional)

# Admin bootstrap password (first run seeds the "admin" user). Default: "admin".
# CT_ADMIN_PASSWORD=change-me

# Persistence DB path (default: ./control-tower.db). Use a temp path for testing.
# CT_DB_PATH=./control-tower.db

# Built-in MCP monitoring: set to "off" to disable host discovery on startup.
# CT_MONITOR_MCP=off

# ── Executive summary (CEO / CTO view) ──────────────────────────────────────
# The executive summary works out-of-the-box with a built-in rule engine (no key).
# If ANTHROPIC_API_KEY is set, the *narrative* is upgraded to a Claude-written one;
# any error/timeout silently falls back to the rule-based narrative.
# ANTHROPIC_API_KEY=
# CONTROL_TOWER_SUMMARY_MODEL=claude-sonnet-4-6
