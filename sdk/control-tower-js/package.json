{
  "name": "control-tower-sdk",
  "version": "1.0.0",
  "description": "Drop-in SDK for Node.js agents to report status, tokens, cost and tool calls to the Agent Control Tower.",
  "type": "module",
  "main": "./controlTower.js",
  "exports": {
    ".": "./controlTower.js",
    "./otel": "./otel.js",
    "./tokenCounter": "./tokenCounter.js"
  },
  "bin": { "control-tower-mcp-proxy": "./mcp-proxy.js" },
  "files": ["controlTower.js", "otel.js", "tokenCounter.js", "mcp-proxy.js", "README.md"],
  "engines": { "node": ">=18" },
  "keywords": ["agent", "observability", "control-tower", "llm", "monitoring", "opentelemetry"],
  "license": "MIT",
  "optionalDependencies": {
    "@langchain/core": "^1.0.0",
    "llama3-tokenizer-js": "^1.2.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0"
  }
}
